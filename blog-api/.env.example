# App
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Database
# Use one of these patterns depending on your DB choice.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/blog_api

# Optional split DB config (if your future DB client needs separate fields)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blog_api
DB_USER=postgres
DB_PASSWORD=postgres

